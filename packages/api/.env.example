# Server Configuration
NODE_ENV=development
PORT=3001
LOG_LEVEL=info

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Database Configuration (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/__PROJECT_NAME__?schema=public"

# Session signing (wallet auth, D-001) — 32+ random bytes
SESSION_SECRET=your-super-secret-key-change-in-production-must-be-32-chars-min

# Blob storage
BLOB_READ_WRITE_TOKEN=

# Stellar / Soroban
STELLAR_NETWORK=testnet
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
KOMUNIFY_CONTRACT_ID=
USDC_CONTRACT_ID=
