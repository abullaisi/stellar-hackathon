{
  "name": "komunify",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun --parallel -r dev",
    "build": "bun --parallel -r build",
    "typecheck": "bun --parallel -r typecheck",
    "lint": "bun --parallel -r lint",
    "format": "bun --parallel -r format",
    "contract:test": "cd contracts && cargo test",
    "contract:build": "cd contracts && stellar contract build",
    "contract:bindings": "make bindings"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "prettier": "^3.4.2"
  }
}